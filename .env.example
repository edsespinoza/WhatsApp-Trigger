APP_NAME=WhatsTrigger
APP_ENV=local
APP_KEY=
APP_DEBUG=false   # Mude para 'true' apenas em desenvolvimento local
APP_URL=http://localhost

# ─── Sessão ─────────────────────────────────────────────────────────────
SESSION_LIFETIME=120      # Minutos antes da sessão expirar

# ─── Banco de dados ───────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=whatstrigger
DB_USERNAME=whatstrigger
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Fila ─────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────────
WHATSAPP_API_TYPE=evolution
WHATSAPP_API_URL=http://evolution-api:8080
WHATSAPP_API_KEY=troque-em-producao
WHATSAPP_INSTANCE_ID=

# ─── Billing (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=      # Usar 'stripe listen --print-secret' para obter
STRIPE_PRICE_STARTER=       # ID do Price no Stripe Dashboard
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
